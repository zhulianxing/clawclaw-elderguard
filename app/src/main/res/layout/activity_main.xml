<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- ============ 顶部 AppBar（主流 App 标配） ============ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="0dp"
        app:elevation="0dp"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:elevation="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="安巢"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingTop="@dimen/space_md"
            android:paddingBottom="@dimen/space_xxl">

            <!-- ============ 状态大卡片（核心视觉锚点） ============ -->
            <LinearLayout
                android:id="@+id/card_monitor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_status_selector"
                android:padding="@dimen/space_lg">

                <!-- 状态行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/indicator_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_indicator_state"/>

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_sm"
                        android:text="待启动"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_license"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <!-- 副提示 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="三重守护 · 跌倒 / 语音 / 静止"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body"/>

                <!-- 主行动按钮（卡片内） -->
                <Button
                    android:id="@+id/btn_start"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_btn_primary"
                    android:text="启动监护"
                    android:textColor="@color/text_on_primary"
                    android:textSize="@dimen/text_body_lg"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:drawableStart="@drawable/ic_start"
                    android:drawableTint="@color/text_on_primary"
                    android:drawablePadding="8dp"
                    android:paddingStart="24dp"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"
                    android:contentDescription="启动监护"/>

                <Button
                    android:id="@+id/btn_stop"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_btn_stop_outline"
                    android:text="停止监护"
                    android:textColor="@color/alert_red"
                    android:textSize="@dimen/text_body_lg"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_stop"
                    android:drawableTint="@color/alert_red"
                    android:drawablePadding="8dp"
                    android:paddingStart="24dp"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"
                    android:visibility="gone"
                    android:contentDescription="停止监护"/>

                <Button
                    android:id="@+id/btn_preview"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="@dimen/space_xs"
                    android:background="@drawable/bg_btn_outline"
                    android:text="查看画面"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_preview"
                    android:drawableTint="@color/primary"
                    android:drawablePadding="8dp"
                    android:paddingStart="16dp"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null"
                    android:visibility="gone"
                    android:contentDescription="查看摄像头画面"/>
            </LinearLayout>

            <!-- ============ 最近事件（无卡片，纯文字） ============ -->
            <LinearLayout
                android:id="@+id/layout_recent_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:orientation="horizontal"
                android:padding="@dimen/space_sm"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最近"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_caption"/>

                <TextView
                    android:id="@+id/tv_log"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_sm"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_caption"/>
            </LinearLayout>

            <!-- ============ 功能入口（列表式，主流 App 风格） ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="功能"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <!-- 列表卡片容器 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:divider="@drawable/divider_horizontal"
                android:showDividers="middle">

                <!-- 联系人 -->
                <LinearLayout
                    android:id="@+id/btn_contacts"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/space_md"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_contacts"
                        android:contentDescription="@null"
                        app:tint="@color/primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:text="紧急联系人"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_body_lg"/>
                </LinearLayout>

                <!-- 事件日志 -->
                <LinearLayout
                    android:id="@+id/btn_logs"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/space_md"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_logs"
                        android:contentDescription="@null"
                        app:tint="@color/primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:text="事件日志"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_body_lg"/>
                </LinearLayout>

                <!-- 设置 -->
                <LinearLayout
                    android:id="@+id/btn_settings"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/space_md"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_settings"
                        android:contentDescription="@null"
                        app:tint="@color/primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:text="设置"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_body_lg"/>
                </LinearLayout>

                <!-- 输入激活码 -->
                <LinearLayout
                    android:id="@+id/btn_activate"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/space_md"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_activate"
                        android:contentDescription="@null"
                        app:tint="@color/primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:text="输入激活码"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_body_lg"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ============ 功能详解（折叠） ============ -->
            <LinearLayout
                android:id="@+id/header_details"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_lg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="功能详解"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body_lg"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_details_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="展开"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_caption"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_sm"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/space_md">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/safe_green"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="跌倒检测"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="MediaPipe Pose 33 关键点 + 加速度计融合，SVM > 2g 候选 + 姿态躺下判定，持续 3-8 秒触发。"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/space_md">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="语音求救识别"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="Vosk 离线中文模型，识别救命/帮帮我/救救我等 7 个关键词，完全离线无网络。"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="@dimen/space_md">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="match_parent"
                        android:background="@color/warning_orange"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="静止异常告警"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:text="30 帧姿态位移方差低于阈值，持续可配置时长（默认 10 分钟）触发，防止昏迷场景。"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption"
                            android:lineSpacingExtra="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 底部说明 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xxl"
                android:gravity="center"
                android:text="完全离线 · 隐私零泄露\n¥268 买断 · 7 天免费试用"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
