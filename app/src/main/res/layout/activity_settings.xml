<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="检测功能"
            android:textColor="#1565C0"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/sw_fall_detection"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="跌倒检测（摄像头）"
            android:textSize="16sp" />

        <Switch
            android:id="@+id/sw_voice_detection"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="语音求救识别"
            android:textSize="16sp" />

        <Switch
            android:id="@+id/sw_stillness_detection"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="长时间静止检测"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="#DDD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="静止告警阈值"
            android:textColor="#1565C0"
            android:textSize="18sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/sb_stillness_minutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="25"
            android:progress="5" />

        <TextView
            android:id="@+id/tv_stillness_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="10 分钟"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="#DDD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="告警延迟（避免误报）"
            android:textColor="#1565C0"
            android:textSize="18sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/sb_alert_delay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="11"
            android:progress="4" />

        <TextView
            android:id="@+id/tv_alert_delay_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="30 秒"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
