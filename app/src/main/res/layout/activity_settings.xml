<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="0dp"
        app:elevation="0dp"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            android:elevation="0dp"
            app:elevation="0dp"
            app:title="设置"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- ============ 分组 1：检测功能 ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="检测功能"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <!-- 跌倒检测 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feature_fall"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="跌倒检测"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg" />

                    <Switch
                        android:id="@+id/sw_fall_detection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/primary"
                        android:trackTint="@color/primary_light" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <!-- 语音求救识别 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feature_voice"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="语音求救识别"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg" />

                    <Switch
                        android:id="@+id/sw_voice_detection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/primary"
                        android:trackTint="@color/primary_light" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <!-- 长时间静止检测 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feature_stillness"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="长时间静止检测"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg" />

                    <Switch
                        android:id="@+id/sw_stillness_detection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/primary"
                        android:trackTint="@color/primary_light" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============ 分组 2：检测状态 ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="检测状态"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feature_fall"
                        app:tint="@color/safe_green" />

                    <TextView
                        android:id="@+id/tv_pose_state"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:text="等待启动监护..."
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body_lg" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============ 分组 3：告警参数 ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="告警参数"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <!-- 静止告警阈值 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="静止告警阈值"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body_lg" />

                        <TextView
                            android:id="@+id/tv_stillness_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="64dp"
                            android:text="10 分钟"
                            android:textAlignment="viewEnd"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_body_lg"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/sb_stillness_minutes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="55"
                        android:progress="5"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/primary"
                        android:trackTint="@color/text_hint" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <!-- 告警延迟 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="告警延迟"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body_lg" />

                        <TextView
                            android:id="@+id/tv_alert_delay_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="64dp"
                            android:text="30 秒"
                            android:textAlignment="viewEnd"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_body_lg"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/sb_alert_delay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:max="10"
                        android:progress="4"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/primary"
                        android:trackTint="@color/text_hint" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <!-- 告警短信模板 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="告警短信模板"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg" />

                    <EditText
                        android:id="@+id/et_sms_template"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_card"
                        android:gravity="top"
                        android:hint="告警短信内容..."
                        android:inputType="textMultiLine"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="@dimen/text_body" />

                    <Button
                        android:id="@+id/btn_save_sms"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_btn_primary"
                        android:minWidth="88dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="保存"
                        android:textAllCaps="false"
                        android:textColor="@color/text_on_primary"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============ 分组 4：其他 ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="其他"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_logs"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/primary"
                    android:gravity="start|center_vertical"
                    android:minHeight="56dp"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="隐私政策  >"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body_lg" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <Button
                    android:id="@+id/btn_test_fall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_feature_fall"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/primary"
                    android:gravity="start|center_vertical"
                    android:minHeight="56dp"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="模拟跌倒告警"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body_lg" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <Button
                    android:id="@+id/btn_test_voice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_feature_voice"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/primary"
                    android:gravity="start|center_vertical"
                    android:minHeight="56dp"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="模拟语音求救"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body_lg" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="64dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <Button
                    android:id="@+id/btn_test_stillness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:drawableStart="@drawable/ic_feature_stillness"
                    android:drawablePadding="16dp"
                    android:drawableTint="@color/primary"
                    android:gravity="start|center_vertical"
                    android:minHeight="56dp"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp"
                    android:text="模拟静止告警"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body_lg" />
            </LinearLayout>

            <!-- ============ 分组 5：关于 ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="关于"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:divider="@drawable/divider_horizontal"
                android:showDividers="middle">

                <!-- 访问官网 -->
                <LinearLayout
                    android:id="@+id/btn_website"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/space_md"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_activate"
                        android:contentDescription="@null"
                        app:tint="@color/primary"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="访问官网激活"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body_lg"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="www.clawclaw.tech"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_caption"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_body_lg"/>
                </LinearLayout>

                <!-- 版本号 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="@dimen/space_md">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_settings"
                        android:contentDescription="@null"
                        app:tint="@color/primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_md"
                        android:text="版本号"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg"/>

                    <TextView
                        android:id="@+id/tv_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_body"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ============ 版权信息 ============ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="@dimen/space_xl"
                android:paddingBottom="@dimen/space_md">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="安巢 AnNest"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="© 2026 ClawClaw.tech"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_caption"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="ClawClaw Technology Co., Ltd."
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_caption"/>

                <TextView
                    android:id="@+id/tv_website_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:text="www.clawclaw.tech"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/space_xs"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
