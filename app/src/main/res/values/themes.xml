<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ElderGuard" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <style name="Theme.ElderGuard.Fullscreen" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <color name="safe_green">#4CAF50</color>
    <color name="warning_orange">#FF9800</color>
    <color name="alert_red">#F44336</color>
</resources>
